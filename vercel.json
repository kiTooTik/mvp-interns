{
    "version": 2,
    "cleanUrls": true,
    "builds": [
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": { "distDir": "dist" }
        },
        {
            "src": "server.cjs",
            "use": "@vercel/node"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/server.cjs"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}