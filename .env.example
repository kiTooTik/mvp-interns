# Supabase Configuration (use your own values from Dashboard → Settings → API)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
# Main app client uses this (can be same as anon key)
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# For API Server (Node / Vercel)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional: API base URL for frontend (leave empty for same-origin)
# VITE_API_URL=

# Docker / Production
NODE_ENV=production

# Optional: Custom Ports
# APP_PORT=8080
# API_PORT=3002
